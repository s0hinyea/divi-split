{
  "expo": {
    "name": "Divi",
    "slug": "divi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "divi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.divi.app",
      "infoDictionary": {
        "NSCameraUsageDescription": "Divi needs access to your camera to scan receipts.",
        "NSPhotoLibraryUsageDescription": "Divi needs access to your photos so you can upload receipts.",
        "NSContactsUsageDescription": "Divi needs access to your contacts to quickly assign items to friends."
      }
    },
    "android": {
      "package": "com.divi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#c1c5cd"
      },
      "permissions": [
        "CAMERA",
        "READ_CONTACTS",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#c1c5cd"
        }
      ],
      "expo-web-browser",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Divi needs access to your camera to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Divi needs access to your photos so you can upload receipts."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Divi needs access to your contacts to let you quickly assign items to friends."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": ""
    }
  }
}
