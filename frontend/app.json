{
  "expo": {
    "name": "Divi",
    "slug": "divi",
    "owner": "s0hinyea123",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "divi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sohi.divi",
      "buildNumber": "33",
      "infoDictionary": {
        "NSCameraUsageDescription": "Divi needs access to your camera to scan receipts.",
        "NSPhotoLibraryUsageDescription": "Divi needs access to your photos so you can upload receipts.",
        "NSContactsUsageDescription": "Divi needs access to your contacts to quickly assign items to friends.",
        "NSMicrophoneUsageDescription": "Divi needs access to your microphone for voice-assisted splitting."
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sohi.divi",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#c1c5cd"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#c1c5cd"
        }
      ],
      "expo-web-browser",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Divi needs access to your camera to scan receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Divi needs access to your photos so you can upload receipts."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Divi needs access to your contacts to let you quickly assign items to friends."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24
          }
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://s0hinyea.github.io/divi-split/privacy_policy.html",
      "router": {},
      "eas": {
        "projectId": "e4b03e3d-d79c-4300-9d55-c869a5508515"
      }
    }
  }
}
